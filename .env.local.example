# --- MongoDB ---
# Local Mongo: mongodb://127.0.0.1:27017
# Atlas:       mongodb+srv://<user>:<pass>@<cluster>/?retryWrites=true&w=majority
MONGODB_URI=
MONGODB_DB=raiseyurvoice

# --- Admin ---
# Change this before deploying. Anyone with this password gets full admin access.
ADMIN_PASSWORD=change-me-now

# Long random string used to sign admin session cookies.
# Generate one with:   openssl rand -hex 32
ADMIN_JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars

# --- Cloudinary (file uploads) ---
# Public values — these are sent to the browser so users can upload directly.
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=

# Server-only secrets — used to generate signed download URLs on the admin page.
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Optional
NEXT_PUBLIC_SITE_NAME=Awaaz Uthao
